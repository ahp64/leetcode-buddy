# Copy to .env and fill in what you have. Anything left blank falls back to
# logging the notification to the server console instead of sending it.

PORT=3000

# --- Email reminders (any SMTP provider: Gmail app password, Mailgun, etc.) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="LeetCode Buddy <buddy@example.com>"

# --- SMS reminders (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Twilio trial accounts reject freeform SMS bodies and require a
# pre-approved Content Template instead (error 572006). Only needed if
# you're on a trial account — leave blank on a paid account. Create the
# three templates in the Twilio Console (Content Editor) and paste their
# Content SIDs (start with HX...) here — see README for exact template text.
TWILIO_CONTENT_SID_SELF=
TWILIO_CONTENT_SID_BUDDY=
TWILIO_CONTENT_SID_TEST=
