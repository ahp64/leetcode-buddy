# Copy to .env and fill in what you have. Anything left blank falls back to
# logging the notification to the server console instead of sending it.

PORT=3000

# --- Email reminders (any SMTP provider: Gmail app password, Mailgun, etc.) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="LeetCode Buddy <buddy@example.com>"

# --- SMS reminders (Twilio — requires a paid account, not the free trial;
# trial accounts reject freeform SMS bodies and can't create the templates
# that would fix that without upgrading first) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- Push notifications (ntfy) — free, no account, nothing to set here ---
# Each person's topic name lives in their own member entry (ntfyTopic),
# not here. Only set this if you're self-hosting your own ntfy server
# instead of using the free public one.
NTFY_SERVER=
